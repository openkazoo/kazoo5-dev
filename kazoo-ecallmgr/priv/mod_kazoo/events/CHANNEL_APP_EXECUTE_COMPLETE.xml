<event name="CHANNEL_APP_EXECUTE_COMPLETE">

	<!--
	<flags>
		<flag name="uuid-add-flags" value="true"/>
	</flags>
	-->

	<filters>
		<filter type="exclude" name="Application" compare="contains" value="bridge">
			<filters scope="any">
				<filter name="Channel-Flags" type="exclude" compare="contains" value="XFER_ZOMBIE" />
				<filter name="Channel-Flags" type="exclude" compare="contains" value="TRANSFER">
					<filters scope="any">
						<filter name="Channel-Flags" type="include" compare="contains" value="ORIGINATING_XFER" />
					</filters>
				</filter>
				<filter name="Channel-Flags" type="exclude" compare="contains" value="REDIRECT" />
				<filter name="Channel-Flags" type="exclude" compare="contains" value="INTERCEPTED" />
				<filter name="Application-Response" type="exclude" value="NONE" />
			</filters>
		</filter>
	</filters>


	<fields>

		<!--
			* attended transfer on origination
			we replace the Unique-ID to the value of the transfer destination
			so that bridge app can be completed
		-->

		<field name="origination-xfer-setup" type="group">
			<filters>
				<filter type="include" name="Application" compare="contains" value="bridge"/>
				<filter type="include" name="Channel-Flags" compare="contains" value="ORIGINATING_XFER" />
			</filters>
			<fields>
				<field name="variable_satt_uuid" as="Unique-ID" target="input"/>
				<field name="XFER-Hangup-Code" type="first-of" value="variable_last_bridge_proto_specific_hangup_cause|#sip:480" target="input"/>
				<field name="XFER-Hangup-Cause" type="first-of" value="variable_last_bridge_hangup_cause|#NO_ANSWER" target="input"/>
				<field name="XFER-Channel-Answer-State" type="expand" value="${kz_uuid_answer_state(${variable_satt_uuid})}" target="input"/>
			</fields>
		</field>

		<field name="call_event_headers" type="reference" />
		<field name="Event-Name" type="static" value="CHANNEL_EXECUTE_COMPLETE" />
		<field name="application-uuid" type="reference" />
		<field name="Application-Error-Code"/>
		<field name="Application-Error-Msg"/>
		<field name="Channel-Flags"/>

		<field name="Application-Response" type="first-of" value="Application-Response|variable_originate_disposition|variable_endpoint_disposition|#NONE" />

        <!--  bridge specific -->
		<!--
        <field name="Application-Response" type="first-of"
            value="variable_originate_failed_cause|variable_last_bridge_hangup_cause|variable_bridge_hangup_cause|variable_hangup_cause|Hangup-Cause|variable_originate_disposition|variable_endpoint_disposition|#NONE">
	        <filters>
	            <filter name="Application-UUID-Name" type="include" compare="value" value="xbridge" />
	        </filters>

        </field>
		-->


		<field name="Bridge-Hangup-Cause" type="first-of" value="variable_bridge_hangup_cause|variable_last_bridge_hangup_cause" />
		<field name="variable_endpoint_disposition" as="Endpoint-Disposition" /> <!-- code in kapps_call_command should use this variable instead of disposition -->
		<field name="variable_transfer_disposition" as="Transfer-Disposition" />
		<field name="hangup-cause" type="reference" />
		<field name="hangup-code" type="reference" />
		<field name="hangup-phrase" type="reference" />
		<field name="Disposition" type="first-of" value="variable_endpoint_disposition|variable_originate_disposition" />
		<field name="channel-state" type="reference" />

		<field name="Custom-Channel-Vars" type="reference" />
		<field name="Custom-Application-Vars" type="reference" />
		<field name="Custom-SIP-Headers" type="reference" />
		<field name="variable_playback_terminator_used" as="DTMF-Digit" />
		<field name="variable_media_group_id" as="Group-ID" />

		<field name="debug-call" type="reference" />
	</fields>

</event>