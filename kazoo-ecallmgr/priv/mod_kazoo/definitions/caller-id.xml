<definition name="caller-id">
	<field name="caller-id" type="group">
		<filters>
			<filter name="Call-Direction" type="include" compare="value" value="inbound" />
			<!--<filter name="Caller-Endpoint-ID" type="include" compare="exists" />-->
		</filters>
		<fields>
			<field name="Caller-ID-Number" type="first-of"	value="KZ-Caller-ID-Original-Number|KZ-Caller-ID-Number|variable_origination_caller_id_number|variable_effective_caller_id_number|Caller-Caller-ID-Number" />
			<field name="Caller-ID-Name" type="first-of" value="KZ-Caller-ID-Original-Name|KZ-Caller-ID-Name|variable_origination_caller_id_name|variable_effective_caller_id_name|Caller-Caller-ID-Name" />
			<field name="Callee-ID-Number" type="first-of" value="KZ-Destination-Number|KZ-Callee-ID-Number|variable_effective_callee_id_number|Caller-Callee-ID-Number|Other-Leg-Caller-ID-Number" />
		</fields>
	</field>
	<field name="caller-id" type="group">
		<filters>
			<filter name="Call-Direction" type="include" compare="value" value="outbound" />
		</filters>
		<fields>
			<field name="Caller-ID-Number" type="first-of"	value="KZ-Origination-Caller-ID-Number|KZ-Caller-ID-Number|variable_origination_caller_id_number|variable_effective_caller_id_number|Caller-Caller-ID-Number" />
			<field name="Caller-ID-Name" type="first-of" value="KZ-Origination-Caller-ID-Name|KZ-Caller-ID-Name|variable_origination_caller_id_name|variable_effective_caller_id_name|Caller-Caller-ID-Name" />
			<field name="Callee-ID-Number" type="first-of" value="KZ-E164-Destination-Number|KZ-Callee-ID-Number|variable_origination_callee_id_number|variable_effective_callee_id_number|Caller-Callee-ID-Number|Other-Leg-Caller-ID-Number" />
			<field name="Callee-ID-Name" type="first-of" value="KZ-Callee-ID-Name|variable_origination_callee_id_name|variable_effective_callee_id_name|Caller-Callee-ID-Name|Other-Leg-Caller-ID-Name" />
		</fields>
	</field>
	<field name="caller-id" type="group">
		<filters>
			<filter name="Call-Direction" type="include" compare="value" value="outbound" />
			<filter name="Channel-Flags" type="include" compare="contains" value="DIALPLAN" />
		</filters>
		<fields>
			<field name="Caller-ID-Number" type="first-of"	value="KZ-Caller-ID-Number|KZ-Caller-ID-Number|variable_origination_caller_id_number|variable_effective_caller_id_number|Caller-Caller-ID-Number" />
			<field name="Caller-ID-Name" type="first-of" value="KZ-Caller-ID-Name|KZ-Caller-ID-Name|variable_origination_caller_id_name|variable_effective_caller_id_name|Caller-Caller-ID-Name" />
			<field name="Callee-ID-Number" type="first-of" value="KZ-Callee-ID-Number|variable_origination_callee_id_number|variable_effective_callee_id_number|Caller-Callee-ID-Number|Other-Leg-Caller-ID-Number" />
			<field name="Callee-ID-Name" type="first-of" value="KZ-Callee-ID-Name|variable_origination_callee_id_name|variable_effective_callee_id_name|Caller-Callee-ID-Name|Other-Leg-Caller-ID-Name" />
		</fields>
	</field>

	<!--
		loopback inbound inter-account
		use originator caller-id instead of original caller-id
		so that destination account_id sees offnet number from other account
	-->
	<field name="caller-id" type="group">
		<filters>
			<filter name="Call-Direction" type="include" compare="value" value="inbound" />
			<filter name="variable_loopback_leg" type="include" compare="value" value="B" />
			<filter name="variable_ecallmgr_Inception-Account-ID" type="include" compare="exists" />
		</filters>
		<fields>
			<field name="Caller-ID-Number" type="first-of"	value="variable_origination_caller_id_number|Caller-Caller-ID-Number" />
			<field name="Caller-ID-Name" type="first-of" value="variable_origination_caller_id_name|Caller-Caller-ID-Name" />
			<!--
			<field name="Callee-ID-Number" type="first-of" value="KZ-Callee-ID-Number|variable_origination_callee_id_number|variable_effective_callee_id_number|Caller-Callee-ID-Number|Other-Leg-Caller-ID-Number" />
			<field name="Callee-ID-Name" type="first-of" value="KZ-Callee-ID-Name|variable_origination_callee_id_name|variable_effective_callee_id_name|Caller-Callee-ID-Name|Other-Leg-Caller-ID-Name" />
			-->
		</fields>
	</field>
</definition>
