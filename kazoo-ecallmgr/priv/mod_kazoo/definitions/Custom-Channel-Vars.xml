<definition name="Custom-Channel-Vars">
	<field name="Custom-Channel-Vars" type="static" serialize-as="object">
		<fields>

			<field name="ccvs" type="prefixes" exclude-prefix="true" value="X-ecallmgr_|variable_sip_h_X-ecallmgr_|variable_ecallmgr_|ecallmgr_"/>

			<field name="variable_Fetch-UUID" as="Fetch-ID" />
			<field name="Fetch-UUID" as="Fetch-ID" />

			<field name="Referred-To" type="expand"	value="sip:${regex(${url_decode(${variable_sip_refer_to})}|&lt;sips?:(.*)>|%1)}">
				<filters>
					<filter name="variable_sip_refer_to" type="include" compare="exists" />
				</filters>
			</field>
			<field name="variable_sip_h_Referred-By" as="Referred-By" />

			<field name="interaction-id" type="reference" />

            <field name="variable_presence_id" as="Presence-ID"/>
            <!--
			<field name="variable_presence_id" as="Presence-ID">
			     <filters>
			         <filter name="Caller-Resource-ID" type="exclude" compare="exists" />
			     </filters>
			</field>
			 -->

			<!-- <field name="Caller-Endpoint-Presence-ID" as="Presence-ID"/> -->

			<field name="redirect" type="group">
				<filters>
					<filter name="variable_sip_redirected_by" type="include" compare="exists" />
				</filters>
				<fields>
					<field name="Redirected-By" type="expand" value="sip:${regex(${variable_sip_redirected_by}|&lt;sips?:(.*)>|%1)}" />
					<field name="Redirected-By" type="expand" value="sip:${regex(${variable_sip_redirected_by}|&lt;sips?:(.*)>|%1)};endpoint_id=${variable_redirected_by_Endpoint-ID}">
						<filters>
							<filter name="variable_redirected_by_Endpoint-ID" type="include" compare="exists" />
						</filters>
					</field>
					<field name="Redirected-Reason" type="expand" value="${regex(${variable_sip_redirected_by}|reason=(.*)|%1)}" />
				</fields>
			</field>

			<field name="Caller-Privacy-Hide-Number" as="Privacy-Hide-Number" serialize-as="boolean" />
			<field name="Caller-Privacy-Hide-Name" as="Privacy-Hide-Name" serialize-as="boolean" />

		</fields>
	</field>
</definition>
