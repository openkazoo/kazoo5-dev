<definition name="hangup-cause">


	<!--
		original simplified value
	-->
	<!--<field name="Hangup-Cause" type="first-of" value="variable_last_bridge_hangup_cause|Hangup-Cause|variable_originate_failed_cause|variable_hangup_cause|variable_bridge_hangup_cause">-->

	<field name="Hangup-Cause" type="first-of" value="Hangup-Cause|variable_hangup_cause">
		<filters>
			<filter name="Application" type="include" compare="contains" value="bridge" />
		</filters>
	</field>

	<field name="variable_bridge_hangup_cause" as="Hangup-Cause">
		<filters>
			<filter name="Application" type="include" compare="contains" value="bridge" />
			<filter name="variable_bridge_hangup_cause" type="exclude" value="BOWOUT" />
			<filter name="variable_last_bridge_hangup_cause" type="exclude" value="BOWOUT" />
		</filters>
	</field>

	<field name="variable_originate_failed_cause" as="Hangup-Cause">
		<filters>
			<filter name="Application" type="include" compare="contains" value="bridge" />
		</filters>
	</field>
	
	<!--
		this doesn't work well because voicemail is not bridge
		and we can't use 
		   variable_endpoint_disposition
		   variable_last_bridge_hangup_cause
	-->
	<!--
	<field name="Hangup-Cause" type="first-of"
		value="variable_endpoint_disposition|variable_last_bridge_hangup_cause|Hangup-Cause|variable_originate_failed_cause|variable_hangup_cause|variable_bridge_hangup_cause">
		<filters>
			<filter name="Application" type="exclude" compare="contains" value="bridge" />
		</filters>
	</field>
	<field name="Hangup-Cause" type="first-of" value="Hangup-Cause|variable_originate_failed_cause|variable_hangup_cause|variable_bridge_hangup_cause">
		<filters>
			<filter name="Application" type="exclude" compare="contains" value="bridge" />
			<filter name="Call-Direction" type="include" compare="value" value="outbound" />
		</filters>
	</field>
	-->

	<field name="Hangup-Cause" type="first-of" value="Hangup-Cause|variable_originate_failed_cause|variable_hangup_cause">
		<filters>
			<filter name="Application" type="exclude" compare="contains" value="bridge" />
		</filters>
	</field>

	<!-- preserve loopback BOWOUT -->
	<field name="Hangup-Cause" type="first-of" value="variable_hangup_cause">
		<filters>
			<filter name="variable_hangup_cause" type="include" compare="value" value="BOWOUT" />
			<filter name="variable_channel_endpoint_name" type="include" compare="value" value="loopback" />
		</filters>
	</field>

	<field name="Hangup-Cause" type="first-of" value="Hangup-Cause|variable_hangup_cause"/>

	<field name="variable_endpoint_disposition" as="Hangup-Cause">
		<filters>
			<filter name="variable_endpoint_disposition" type="include" compare="value" value="BLIND_TRANSFER" />
		</filters>
	</field>

	<field name="variable_last_bridge_hangup_cause" as="Hangup-Cause">
		<filters>
			<filter name="Call-Direction" type="include" compare="value" value="outbound" />
			<filter name="Caller-Logical-Direction" type="exclude" compare="value" value="inbound" />
			<filter name="last_app" type="exclude" compare="contains" value="intercept" />
			<filter name="variable_bridge_hangup_cause" type="exclude" value="BOWOUT" />
			<filter name="variable_last_bridge_hangup_cause" type="exclude" value="BOWOUT" />
		</filters>
	</field>

	<field name="Hangup-Cause" type="static" value="ATTENDED_TRANSFER">
		<filters>
			<filter name="Channel-Flags" type="include" compare="contains" value="ORIGINATING_XFER" />
		</filters>
	</field>

	<field name="XFER-Hangup-Cause" as="Hangup-Cause"/>

</definition>
