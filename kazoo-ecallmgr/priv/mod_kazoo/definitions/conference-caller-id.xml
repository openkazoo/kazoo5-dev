<definition name="conference-caller-id">
	<field name="CONF-CALLER-ID-IN" type="group">
		<filters>
			<filter name="Call-Direction" type="include" compare="value" value="inbound" />
		</filters>
		<fields>
			<field name="Caller-Caller-ID-Name" as="Caller-ID-Name" />
			<field name="Caller-Caller-ID-Number" as="Caller-ID-Number" />
		</fields>
	</field>
	<field name="CONF-CALLER-ID-OUT" type="group">
		<filters>
			<filter name="Call-Direction" type="include" compare="value" value="outbound" />
		</filters>
		<fields>
			<field name="Caller-ID-Name" type="first-of" value="variable_origination_callee_id_name|Caller-Callee-ID-Name" />
			<field name="Caller-ID-Number" type="first-of" value="variable_origination_callee_id_number|Caller-Callee-ID-Number" />
		</fields>
	</field>
	<field name="CONF-CALLER-ID-OUT-DP" type="group">
		<filters>
			<filter name="Call-Direction" type="include" compare="value" value="outbound" />
			<filter name="Channel-Flags" type="include" compare="contains" value="DIALPLAN" />
		</filters>
		<fields>
			<field name="Caller-Caller-ID-Name" as="Caller-ID-Name" />
			<field name="Caller-Caller-ID-Number" as="Caller-ID-Number" />
		</fields>
	</field>
</definition>
