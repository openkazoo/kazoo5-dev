{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "_id": "system_config.pusher",
    "description": "Schema for pusher system_config",
    "properties": {
        "User-Agents": {
            "default": {},
            "description": "pusher User-Agents",
            "type": "object"
        },
        "apple": {
            "default": {},
            "description": "pusher apple",
            "properties": {
                "apns_topic": {
                    "description": "APNs topic for push notifications payload",
                    "type": "string"
                },
                "auth_type": {
                    "description": "Whether the APNs authentication method is certificate based or token based auth",
                    "enum": [
                        "certdata",
                        "token"
                    ],
                    "type": "string"
                },
                "certificate": {
                    "description": "PEM-encoded key and certificate",
                    "type": "string"
                },
                "enable_custom_apns_push_type": {
                    "default": false,
                    "description": "Whether the app is enabled for custom apns_push_type",
                    "type": "boolean"
                },
                "enabled": {
                    "default": true,
                    "description": "Whether the app is enabled for push notifications",
                    "type": "boolean"
                },
                "headers": {
                    "default": {},
                    "description": "pusher apple headers",
                    "type": "object"
                },
                "host": {
                    "default": "api.push.apple.com",
                    "description": "APNs server host",
                    "type": "string"
                },
                "keepalive_m": {
                    "default": 15,
                    "description": "pusher apple keepalive_m",
                    "minimum": 1,
                    "type": "integer"
                },
                "key_id": {
                    "description": "Key ID of the APNs authentication key (.p8 file) from Apple Developer portal",
                    "type": "string"
                },
                "team_id": {
                    "description": "Apple Developer Team ID (10-character identifier for your developer account)",
                    "type": "string"
                },
                "token_refresh_window": {
                    "default": 55,
                    "description": "Interval (in minutes) for refreshing the APNs auth token",
                    "maximum": 60,
                    "minimum": 20,
                    "type": "integer"
                }
            },
            "type": "object"
        },
        "firebase": {
            "default": {},
            "description": "pusher firebase",
            "properties": {
                "api_key": {
                    "default": "",
                    "description": "API Key for firebase",
                    "type": "string"
                },
                "enabled": {
                    "default": true,
                    "description": "Whether the app is enabled for push notifications",
                    "type": "boolean"
                },
                "headers": {
                    "default": {},
                    "description": "pusher firebase headers",
                    "type": "object"
                }
            },
            "type": "object"
        },
        "firebase_v1": {
            "properties": {
                "enabled": {
                    "default": true,
                    "description": "Whether the app is enabled for push notifications",
                    "type": "boolean"
                },
                "headers": {
                    "default": {},
                    "description": "pusher firebase_v1 headers",
                    "type": "object"
                },
                "service_account": {
                    "description": "The contents of the service account file for an account with adequate permissions for Firebase Cloud Messaging.",
                    "type": "object"
                }
            }
        }
    },
    "type": "object"
}
