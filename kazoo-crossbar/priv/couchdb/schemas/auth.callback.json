{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "_id": "auth.callback",
    "additionalProperties": true,
    "description": "callback for authentication providers",
    "properties": {
        "client_id": {
            "description": "client id, usually application id for OAuth providers",
            "type": "string"
        },
        "code": {
            "description": "access code emitted by provider",
            "type": "string"
        },
        "code_verifier": {
            "description": "The code verifier for the PKCE request, originally generated by the app before the authorization request",
            "type": "string"
        },
        "provider": {
            "description": "provider",
            "type": "string"
        },
        "redirect_uri": {
            "description": "redirect URI",
            "minLength": 7,
            "type": "string"
        },
        "state": {
            "description": "state",
            "type": "string"
        }
    },
    "required": [
        "provider",
        "code",
        "client_id",
        "redirect_uri"
    ],
    "type": "object"
}
