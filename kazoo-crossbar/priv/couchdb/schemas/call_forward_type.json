{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "_id": "call_forward_type",
    "additionalProperties": false,
    "description": "Call Forward Properties",
    "properties": {
        "direct_calls_only": {
            "default": false,
            "type": "boolean"
        },
        "enabled": {
            "default": false,
            "type": "boolean"
        },
        "ignore_early_media": {
            "default": true,
            "type": "boolean"
        },
        "keep_caller_id": {
            "default": true,
            "type": "boolean"
        },
        "number": {
            "maxLength": 35,
            "type": "string"
        },
        "require_keypress": {
            "default": true,
            "type": "boolean"
        }
    },
    "required": [
        "enabled"
    ],
    "type": "object"
}
