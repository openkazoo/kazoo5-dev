{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "_id": "vmboxes",
    "description": "Schema for a voicemail box",
    "properties": {
        "after_forward_action": {
            "default": "save",
            "description": "Action to perform after forwarding a voicemail message",
            "enum": [
                "prompt",
                "save"
            ],
            "type": "string"
        },
        "aliases": {
            "default": [],
            "description": "The voicemail box aliases string list",
            "items": {
                "maxLength": 36,
                "minLength": 1,
                "type": "string"
            },
            "type": "array",
            "uniqueItems": true
        },
        "announcement_only": {
            "default": false,
            "description": "Determine if the mailbox should only play announcements",
            "support_level": "unsupported",
            "type": "boolean"
        },
        "check_if_owner": {
            "default": true,
            "description": "Determines if when the user calls their own voicemail they should be prompted to sign in",
            "support_level": "supported",
            "type": "boolean"
        },
        "delete_after_notify": {
            "default": false,
            "description": "Move the voicemail to delete folder after the notification has been sent",
            "support_level": "supported",
            "type": "boolean"
        },
        "envelope_type": {
            "default": "default",
            "description": "The voicemail envelope type to determine the envelope format",
            "enum": [
                "default",
                "caller_and_time"
            ],
            "type": "string"
        },
        "flags": {
            "description": "Flags set by external applications",
            "items": {
                "type": "string"
            },
            "support_level": "supported",
            "type": "array"
        },
        "include_message_on_notify": {
            "default": true,
            "description": "Whether or not to include the attachment when sending a new voicemail to email notification",
            "support_level": "supported",
            "type": "boolean"
        },
        "include_transcription_on_notify": {
            "default": true,
            "description": "Whether or not to include the transcription when sending a new voicemail to email notification",
            "support_level": "supported",
            "type": "boolean"
        },
        "is_setup": {
            "default": false,
            "description": "Determines if the user has completed the initial configuration",
            "support_level": "supported",
            "type": "boolean"
        },
        "is_voicemail_ff_rw_enabled": {
            "default": false,
            "description": "callflow allow fastforward and rewind during voicemail message playback",
            "type": "boolean"
        },
        "mailbox": {
            "description": "The voicemail box number",
            "maxLength": 30,
            "minLength": 1,
            "support_level": "supported",
            "type": "string"
        },
        "media": {
            "default": {},
            "description": "The media (prompt) parameters",
            "properties": {
                "unavailable": {
                    "description": "The ID of a media object that should be used as the unavailable greeting",
                    "maxLength": 32,
                    "minLength": 32,
                    "support_level": "supported",
                    "type": "string"
                }
            },
            "support_level": "supported",
            "type": "object"
        },
        "media_extension": {
            "default": "mp3",
            "description": "Voicemail audio format",
            "enum": [
                "mp3",
                "mp4",
                "wav"
            ],
            "support_level": "supported",
            "type": "string"
        },
        "members": {
            "description": "List of the Shared VM Box members",
            "items": {
                "properties": {
                    "id": {
                        "description": "Id of the member. It can be User Id or Group Id",
                        "maxLength": 32,
                        "minLength": 32,
                        "type": "string"
                    },
                    "type": {
                        "description": "Type of the member",
                        "enum": [
                            "user",
                            "group"
                        ],
                        "type": "string"
                    }
                },
                "required": [
                    "id",
                    "type"
                ],
                "type": "object"
            },
            "support_level": "supported",
            "type": "array"
        },
        "name": {
            "description": "A friendly name for the voicemail box",
            "maxLength": 128,
            "minLength": 1,
            "support_level": "supported",
            "type": "string"
        },
        "not_configurable": {
            "default": false,
            "description": "Determines if the user can configure this voicemail.",
            "support_level": "supported",
            "type": "boolean"
        },
        "notify": {
            "properties": {
                "callback": {
                    "$ref": "notify.callback"
                }
            },
            "support_level": "supported",
            "type": "object"
        },
        "notify_email_addresses": {
            "default": [],
            "description": "List of email addresses to send notifications to (in addition to owner's email, if any)",
            "items": {
                "format": "email",
                "type": "string"
            },
            "support_level": "supported",
            "type": "array"
        },
        "oldest_message_first": {
            "default": false,
            "description": "Play older voicemail messages before new ones",
            "support_level": "supported",
            "type": "boolean"
        },
        "operator_number": {
            "description": "Alternate/override number to use when calling operator from voicemail",
            "oneOf": [
                {
                    "type": "integer"
                },
                {
                    "type": "string"
                }
            ]
        },
        "owner_id": {
            "description": "The ID of the user object that 'owns' the voicemail box",
            "maxLength": 32,
            "minLength": 32,
            "support_level": "supported",
            "type": "string"
        },
        "pin": {
            "description": "The pin number for the voicemail box",
            "maxLength": 6,
            "minLength": 4,
            "support_level": "supported",
            "type": "string"
        },
        "require_pin": {
            "default": false,
            "description": "Determines if a pin is required to check the voicemail from the users devices",
            "support_level": "supported",
            "type": "boolean"
        },
        "save_after_notify": {
            "default": false,
            "description": "Move the voicemail to save folder after the notification has been sent (This setting will override delete_after_notify)",
            "support_level": "supported",
            "type": "boolean"
        },
        "seek_duration_ms": {
            "default": 10000,
            "description": "callflow fastforward and rewind seek duration",
            "minimum": 0,
            "type": "integer"
        },
        "shared_vmbox": {
            "default": false,
            "description": "Determines if the vmbox is used as Shared VM box",
            "support_level": "supported",
            "type": "boolean"
        },
        "shared_vmbox_notify_owner_email": {
            "default": false,
            "description": "Determines if the owner od the shared vmbox should be notified by email",
            "support_level": "supported",
            "type": "boolean"
        },
        "silence_hits": {
            "description": "The number of consecutive hits to see before the channel is considered silent",
            "minimum": 1,
            "type": "integer"
        },
        "silence_threshold": {
            "description": "Threshold value compared to score - if score drops below threshold, add a hit. Lower threshold means quieter channel before hits start",
            "minimum": 1,
            "type": "integer"
        },
        "skip_envelope": {
            "default": false,
            "description": "Determines if the envelope should be skipped",
            "support_level": "beta",
            "type": "boolean"
        },
        "skip_greeting": {
            "default": false,
            "description": "Determines if the greeting should be skipped",
            "support_level": "supported",
            "type": "boolean"
        },
        "skip_instructions": {
            "default": false,
            "description": "Determines if the instructions after the greeting and prior to composing a message should be played",
            "support_level": "supported",
            "type": "boolean"
        },
        "timezone": {
            "$ref": "timezone",
            "description": "The default timezone",
            "support_level": "supported"
        },
        "transcribe": {
            "default": false,
            "description": "Transcribe voicemail using ASR engine",
            "support_level": "alpha",
            "type": "boolean"
        },
        "vm_message_forward_type": {
            "default": "only_forward",
            "description": "Enable or disable the ability to prepend a message when forwarding a voicemail message",
            "enum": [
                "only_forward",
                "prepend_forward"
            ],
            "support_level": "supported",
            "type": "string"
        }
    },
    "required": [
        "mailbox",
        "name"
    ],
    "type": "object"
}
