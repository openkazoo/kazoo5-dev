{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "_id": "system_config.auth.password",
    "description": "Schema for auth.password system_config",
    "properties": {
        "should_enforce_strength": {
            "default": false,
            "description": "auth password should_enforce_strength",
            "type": "boolean"
        },
        "should_prevent_reuse": {
            "default": false,
            "description": "auth password should_prevent_reuse",
            "type": "boolean"
        },
        "strength_regexes": {
            "default": {
                "digit": {
                    "message": "at least one digit is required",
                    "regex": "[0-9]"
                },
                "lower_case": {
                    "message": "at least one lower case character is required",
                    "regex": "[a-z]"
                },
                "minimum_length": {
                    "message": "minimum password length is 10 characters",
                    "regex": "^.{10,}$"
                },
                "special": {
                    "message": "at least one special character is required",
                    "regex": "[-_.,<>!?@#$%^&*=+(){}[\\]/\\\\|;:'\"]"
                },
                "upper_case": {
                    "message": "at least one upper case character is required",
                    "regex": "[A-Z]"
                }
            },
            "description": "auth password strength_regexes",
            "type": "object"
        }
    },
    "type": "object"
}
