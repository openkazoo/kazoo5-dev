{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "_id": "system_config.crossbar",
    "description": "Schema for crossbar system_config",
    "properties": {
        "allow_fetch_full_docs": {
            "default": false,
            "description": "crossbar allow_fetch_full_docs",
            "type": "boolean"
        },
        "allow_onboarding_setting_id": {
            "default": false,
            "description": "crossbar allow_onboarding_setting_id",
            "type": "boolean"
        },
        "allow_tracing": {
            "default": false,
            "description": "crossbar allow tracing",
            "type": "boolean"
        },
        "allowed_modules_fetch_full_docs": {
            "patternProperties": {
                ".+": {
                    "description": "crossbar allowed_modules_fetch_full_docs  +",
                    "type": "boolean"
                }
            }
        },
        "api_auth_tokens": {
            "default": 35,
            "description": "Default token cost when using api_auth",
            "type": "integer"
        },
        "autoload_modules": {
            "description": "crossbar autoload modules",
            "items": {
                "description": "name of the crossbar module to load",
                "type": "string"
            },
            "type": "array"
        },
        "check_reverse_proxies": {
            "default": true,
            "description": "If request is proxied, should Crossbar check allowed reverse proxies",
            "type": "boolean"
        },
        "compress_response_body": {
            "default": true,
            "description": "crossbar compress response body",
            "type": "boolean"
        },
        "conference_auth_tokens": {
            "default": 35,
            "description": "Default token cost when using conference_auth",
            "type": "integer"
        },
        "cowboy_custom_routes_handlers": {
            "default": [],
            "description": "crossbar cowboy_custom_routes_handlers",
            "items": {
                "type": "string"
            },
            "type": "array"
        },
        "custom_route_modules": {
            "default": [],
            "description": "Defines a list of single route URL segment for short circuiting how crossbar parses the URL. When crossbar sees this in one of the segment, it stops processing and adds any remaining segments as params. This segment name should be a Crossbar API module as usual.",
            "items": {
                "type": "string"
            },
            "type": "array"
        },
        "default_allow_anonymous_quickcalls": {
            "default": true,
            "description": "crossbar default allow anonymous quickcalls",
            "type": "boolean"
        },
        "default_language": {
            "default": "en-US",
            "description": "crossbar default language",
            "type": "string"
        },
        "desktop_auth_tokens": {
            "default": 35,
            "description": "Default token cost when using desktop_auth API",
            "type": "integer"
        },
        "display_dependency_list": {
            "default": true,
            "description": "When toggled to false, the Erlang dependency list will not be displayed when accessing the root API URL",
            "type": "boolean"
        },
        "ensure_valid_schema": {
            "default": true,
            "description": "crossbar ensure valid schema",
            "type": "boolean"
        },
        "idle_timeout_ms": {
            "default": 120000,
            "description": "timeout (in milliseconds) when no data is being sent",
            "type": "integer"
        },
        "include_auth_token": {
            "default": true,
            "description": "crossbar include_auth_token",
            "type": "boolean"
        },
        "ip": {
            "description": "IP address to bind to when starting up",
            "type": "string"
        },
        "load_view_chunk_size": {
            "default": 50,
            "description": "crossbar load_view_chunk_size",
            "minimum": 1,
            "type": "integer"
        },
        "magic_path_patterns": {
            "default": [
                "/:version/accounts/:account_id/vmboxes/:box_id/messages/:message_id/raw",
                "/:version/accounts/:account_id/faxes/:direction/:fax_id/attachment",
                "/:version/accounts/:account_id/presence/:reportid"
            ],
            "description": "crossbar magic path patterns",
            "items": {
                "type": "string"
            },
            "type": "array"
        },
        "max_upload_size": {
            "default": 8000000,
            "description": "crossbar maximum upload size",
            "type": "integer"
        },
        "maximum_chunk_size": {
            "default": 50,
            "description": "crossbar maximum_chunk_size",
            "minimum": 1,
            "type": "integer"
        },
        "maximum_range": {
            "default": 2682000,
            "description": "crossbar maximum range",
            "minimum": 1,
            "type": "integer"
        },
        "mdn_provider": {
            "default": "tower-of-power",
            "description": "crossbar mdn_provider",
            "type": "string"
        },
        "pagination_page_size": {
            "default": 50,
            "description": "Default page size for pagination when unspecified by client request",
            "minimum": 1,
            "type": "integer"
        },
        "password_expiry_s": {
            "description": "Password expiry from password creation time, in seconds",
            "type": "integer"
        },
        "port": {
            "default": 8000,
            "description": "Cleartext API port to bind to on startup",
            "type": "integer"
        },
        "pretty_metrics": {
            "default": true,
            "description": "crossbar pretty metrics",
            "type": "boolean"
        },
        "refresh_app_keys": {
            "default": [
                "name",
                "i18n",
                "tags",
                "author",
                "version",
                "license",
                "price",
                "icon",
                "screenshots",
                "api_url",
                "phase"
            ],
            "description": "crossbar refresh_app_keys",
            "items": {
                "type": "string"
            },
            "type": "array"
        },
        "request_memory_limit": {
            "description": "Limit the amount of memory an API request can consume (in bytes)",
            "type": "integer"
        },
        "request_timeout_ms": {
            "default": 10000,
            "description": "crossbar request timeout in milliseconds",
            "type": "integer"
        },
        "reset_id_expiry_s": {
            "default": 3600,
            "description": "crossbar reset_id expiry in seconds",
            "type": "integer"
        },
        "reset_id_size": {
            "default": 137,
            "description": "crossbar reset id size",
            "type": "integer"
        },
        "reverse_proxies": {
            "default": [
                "127.0.0.1"
            ],
            "description": "crossbar reverse proxies",
            "items": {
                "type": "string"
            },
            "type": "array"
        },
        "schema_strict_validation": {
            "default": false,
            "description": "crossbar schema strict validation",
            "type": "boolean"
        },
        "simple_authz_ignored_modules": {
            "default": [],
            "description": "crossbar simple_authz_ignored_modules",
            "items": {
                "type": "string"
            },
            "type": "array"
        },
        "ssl_ca_cert": {
            "description": "crossbar ssl ca cert",
            "type": "string"
        },
        "ssl_cert": {
            "description": "crossbar ssl cert",
            "type": "string"
        },
        "ssl_key": {
            "description": "crossbar ssl key",
            "type": "string"
        },
        "ssl_password": {
            "default": "",
            "description": "crossbar ssl password",
            "type": "string"
        },
        "ssl_port": {
            "default": 8443,
            "description": "crossbar ssl port",
            "type": "integer"
        },
        "ssl_workers": {
            "default": 100,
            "description": "crossbar ssl workers",
            "type": "integer"
        },
        "stability_level": {
            "description": "crossbar stability_level",
            "enum": [
                "alpha",
                "beta",
                "stable"
            ],
            "type": "string"
        },
        "token_costs": {
            "default": 1,
            "description": "Token costs for API requests",
            "type": "integer"
        },
        "trace_path": {
            "default": "/tmp",
            "description": "crossbar trace path",
            "type": "string"
        },
        "use_plaintext": {
            "default": true,
            "description": "Toggle whether to start a cleartext socket listener",
            "type": "boolean"
        },
        "use_ssl": {
            "default": false,
            "description": "Toggle whether to start a TLS socket listener",
            "type": "boolean"
        },
        "user_auth_tokens": {
            "default": 35,
            "description": "Default token cost when using user_auth",
            "type": "integer"
        },
        "workers": {
            "default": 100,
            "description": "crossbar workers",
            "type": "integer"
        }
    },
    "type": "object"
}
