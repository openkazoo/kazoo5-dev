{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "_id": "system_config.default",
    "description": "Schema for default system_config",
    "properties": {
        "max_upload_size": {
            "default": 20,
            "description": "maximum upload file size (mega byte)",
            "type": "integer"
