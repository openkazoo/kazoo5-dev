{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "_id": "tone",
    "description": "Validator for a teletone config",
    "properties": {
        "duration_off": {
            "description": "duration, in milliseconds, for tone to be off",
            "type": "integer"
        },
        "duration_on": {
            "description": "duration, in milliseconds, for the tone to be on",
            "type": "integer"
        },
        "frequencies": {
            "description": "list of Frequencies to play",
            "items": {
                "description": "Frequency, in Hz, to play",
                "type": "integer"
            },
            "minItems": 1,
            "type": "array"
        },
        "repeat": {
            "description": "How many times to loop the tones",
            "type": "integer"
        },
        "volume": {
            "description": "Volume, in dB. 0 = max, negative = quieter",
            "maximum": 0,
            "type": "integer"
        }
    },
    "required": [
        "frequencies",
        "duration_off",
        "duration_on"
    ],
    "type": "object"
}
